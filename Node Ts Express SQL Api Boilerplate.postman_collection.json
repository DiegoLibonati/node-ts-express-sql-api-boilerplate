{
  "info": {
    "name": "Node Ts Express SQL Api Boilerplate",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5050",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "[GET] - Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          }
        }
      ]
    },
    {
      "name": "Notes",
      "item": [
        {
          "name": "[GET] - Get All Notes",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/notes",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "notes"]
            }
          }
        },
        {
          "name": "[GET] - Get Note By Id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/notes/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "notes", "1"]
            }
          }
        },
        {
          "name": "[POST] - Create Note",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My first note\",\n  \"content\": \"This is the content of my first note.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/notes",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "notes"]
            }
          }
        },
        {
          "name": "[PUT] - Update Note",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated title\",\n  \"content\": \"Updated content.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/notes/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "notes", "1"]
            }
          }
        },
        {
          "name": "[DELETE] - Delete Note",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/v1/notes/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "notes", "1"]
            }
          }
        }
      ]
    }
  ]
}
